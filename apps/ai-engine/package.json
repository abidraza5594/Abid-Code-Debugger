{
  "name": "@angular-ai-debugger/ai-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch & node --watch dist/index.js",
    "start": "node dist/index.js",
    "clean": "rimraf dist .tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "report": "node dist/reports/cli.js"
  },
  "dependencies": {
    "@angular-ai-debugger/shared-types": "workspace:*",
    "@mistralai/mistralai": "2.2.1",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ts-morph": "^24.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
