# Mistral API key — required for non-heuristic AI analysis. Get one from https://console.mistral.ai
MISTRAL_API_KEY=

# Model selection. These are the May 2026 production model IDs; override if Mistral renames them.
MISTRAL_ROOT_CAUSE_MODEL=mistral-large-3-25-12
MISTRAL_FIX_MODEL=codestral-25-08
MISTRAL_REFACTOR_MODEL=devstral-2-25-12
MISTRAL_CLASSIFY_MODEL=ministral-3-8b-25-12

# Network
HTTP_PORT=5757
WS_PORT=5758

# Persistence
DATA_DIR=./data
SQLITE_FILE=engine.db

# Tuning
MAX_EVENTS_PER_REQUEST=2000
ROOT_CAUSE_MAX_OUTPUT_TOKENS=1200
FIX_MAX_OUTPUT_TOKENS=1500
