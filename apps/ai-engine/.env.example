# AI provider: mistral, ollama, or heuristic.
AI_PROVIDER=mistral

# Mistral API key - required when AI_PROVIDER=mistral.
# Keep this in apps/ai-engine/.env, never in committed source.
MISTRAL_API_KEY= 

# Mistral model selection.
MISTRAL_ROOT_CAUSE_MODEL=mistral-large-3-25-12
MISTRAL_FIX_MODEL=codestral-25-08
MISTRAL_REFACTOR_MODEL=devstral-2-25-12
MISTRAL_CLASSIFY_MODEL=ministral-3-8b-25-12

# Local Ollama support. Used when AI_PROVIDER=ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_ROOT_CAUSE_MODEL=qwen2.5-coder:14b
OLLAMA_FIX_MODEL=qwen2.5-coder:14b

# Network
HTTP_PORT=5757
WS_PORT=5758

# Persistence
DATA_DIR=./data
SQLITE_FILE=engine.db

# Tuning
MAX_EVENTS_PER_REQUEST=2000
ROOT_CAUSE_MAX_OUTPUT_TOKENS=1200
FIX_MAX_OUTPUT_TOKENS=1500
